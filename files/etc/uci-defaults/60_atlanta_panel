input::placeholder{color:var(--dim)}
.row{display:flex;gap:7px;flex-wrap:wrap;margin-top:10px;justify-content:center}
.btn{appearance:none;border-radius:var(--rs);padding:9px 14px;font-size:12px;font-weight:700;cursor:pointer;min-height:38px;transition:opacity .12s,transform .08s,box-shadow .12s;touch-action:manipulation;-webkit-user-select:none;user-select:none;display:inline-flex;align-items:center;justify-content:center;gap:6px;white-space:nowrap}
.btn:active{transform:scale(.95)}
.btn.primary{background:linear-gradient(135deg,var(--acc),var(--acc2),var(--acc3));color:#fff;border:0;font-weight:700;box-shadow:0 3px 12px rgba(10,179,255,.18)}
.btn.primary:hover{opacity:.9;box-shadow:0 4px 16px rgba(10,179,255,.25)}
.btn.secondary{background:var(--s3);color:var(--txt);border:1px solid var(--b2)}
.btn.secondary:hover{background:rgba(255,255,255,.1)}
.btn.danger{background:rgba(240,64,64,.08);color:#ff8888;border:1px solid rgba(240,64,64,.18)}
.btn.danger:hover{background:rgba(240,64,64,.14)}
.hint{color:var(--mut);padding:8px 11px;border-radius:var(--rx);border:1px solid var(--b1);background:rgba(255,255,255,.02);font-size:11px;line-height:1.5;text-align:center}
.debug-section{margin-top:10px;padding-top:8px;border-top:1px solid rgba(255,255,255,.05)}
.debug-title{font-size:10px;font-weight:600;color:var(--dim);text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px;text-align:center}
.debug-body{display:block;margin-top:0}
.drow{display:flex;align-items:center;justify-content:space-between;gap:10px;padding:5px 0;border-bottom:1px solid rgba(255,255,255,.04);font-size:11px}
.drow:last-child{border-bottom:0}
.drow-k{color:var(--dim)}
.drow-v{font-weight:700;font-family:'SF Mono',ui-monospace,monospace;font-size:10px;color:#7ec8ff;text-align:right;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:160px}
.copywrap{display:flex;gap:6px;align-items:center;flex-wrap:wrap}
.copyid{font-weight:700;font-size:12px}
.copybtn{border:1px solid var(--b1);background:var(--s2);color:var(--txt);border-radius:var(--rx);padding:4px 8px;cursor:pointer;min-height:28px;font-size:11px;font-weight:600;transition:background .12s;touch-action:manipulation}
.copybtn:hover{background:var(--s3)}
.toast{display:inline-block;color:var(--ok);font-weight:700;opacity:0;transition:opacity .2s;font-size:11px}
.toast.on{opacity:1}
.hidden{display:none !important}
.card p{text-align:center}
/* ── Расширенные настройки ── */
.adv-wrap{background:var(--s1);border:1px solid var(--b1);border-radius:var(--r);margin-bottom:12px;overflow:hidden;transition:border-color .15s}
.adv-wrap:hover{border-color:var(--b2)}
.adv-hdr{display:flex;align-items:center;justify-content:space-between;gap:14px;padding:18px 20px;cursor:pointer;user-select:none;-webkit-user-select:none;transition:background .12s}
.adv-hdr:hover{background:rgba(255,255,255,.03)}
.adv-hdr-left{display:flex;align-items:center;gap:14px}
.adv-icon{font-size:22px;flex-shrink:0}
.adv-title{font-size:15px;font-weight:800;letter-spacing:-.2px}
.adv-sub{font-size:11px;color:var(--dim);margin-top:2px}
.adv-arr{font-size:20px;color:var(--dim);transition:transform .25s;width:32px;height:32px;display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,.05);border-radius:50%;flex-shrink:0}
.adv-wrap.open .adv-arr{transform:rotate(180deg)}
.adv-body{display:none;border-top:1px solid var(--b1)}
.adv-wrap.open .adv-body{display:block;animation:fadeUp .2s ease both}
.adv-inner{padding:16px;display:flex;flex-direction:column;gap:8px}
#burgerBtn{
  display:inline-flex;
  width:42px;height:42px;
  border:1px solid var(--b2);
  border-radius:10px;
  background:var(--s2);
  color:var(--txt);font-size:20px;font-weight:800;
  cursor:pointer;
  touch-action:manipulation;-webkit-user-select:none;user-select:none;
  align-items:center;justify-content:center;
  flex-shrink:0;
}
#burgerBtn:active{opacity:.7}
#burgerBtn.is-open{background:var(--acc);color:#fff;border-color:transparent}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
@media(max-width:1200px){.main-grid{grid-template-columns:1fr 1fr}}
@media(max-width:800px){.main-grid,.bot-grid{grid-template-columns:1fr}}
@media(max-width:860px),(hover:none) and (pointer:coarse){
  .header{gap:8px;margin-bottom:6px}
  input,select{font-size:16px !important}
  .nav{width:min(280px,88vw)}
  .btn{min-height:42px}
  .wrap{padding-bottom:32px}
  .status-bar{gap:3px;flex-wrap:wrap}
  .si-left{padding:4px 7px;gap:4px}
  .si-right{display:none}
  .sname{font-size:10px}
  .si-wan .sval,.si-bypass .sval{font-size:10px}
  .card{padding:12px}
}
/* ══════════════════════════════════════════════════════
   СВЕТЛАЯ ТЕМА — стиль Atlanta VPS
   ══════════════════════════════════════════════════════ */
[data-theme="light"]{
  --bg:#eef2f9;
  --s1:#ffffff;--s2:#f7f9fc;--s3:#edf0f7;
  --b1:#dde3ef;--b2:#c5cfe0;
  --txt:#0f172a;--mut:#3d4f6b;--dim:#64748b;
  --acc:#2563eb;--acc2:#1d4ed8;--acc3:#1e40af;
  --ok:#15803d;--bad:#dc2626;--warn:#b45309;
  --r:16px;--rs:12px;--rx:8px;
  --shadow-sm:0 1px 3px rgba(15,23,42,.08),0 1px 2px rgba(15,23,42,.04);
  --shadow-md:0 4px 16px rgba(15,23,42,.08),0 1px 4px rgba(15,23,42,.04);
  --shadow-lg:0 8px 32px rgba(15,23,42,.1),0 2px 8px rgba(15,23,42,.05);
}

/* ── Базовые элементы ── */
[data-theme="light"] body{background:var(--bg);color:var(--txt)}
[data-theme="light"] ::-webkit-scrollbar-thumb{background:#c5cfe0;border-radius:99px}

/* ── Фоновый паттерн страницы ── */
[data-theme="light"] body::before{
  content:'';position:fixed;inset:0;z-index:-1;
  background:
    radial-gradient(ellipse 80% 50% at 20% -10%,rgba(37,99,235,.07) 0%,transparent 60%),
    radial-gradient(ellipse 60% 40% at 90% 110%,rgba(29,78,216,.05) 0%,transparent 60%);
  pointer-events:none;
}

/* ── Шапка ── */
[data-theme="light"] .wrap{background:transparent}
[data-theme="light"] .panel-footer{color:#64748b}
[data-theme="light"] div[style*="background:var(--bg)"]{background:var(--bg) !important}
[data-theme="light"] body > div[style*="text-align:center"]{background:transparent !important}
[data-theme="light"] #burgerBtn{background:#fff;border-color:#dde3ef;color:#0f172a;box-shadow:var(--shadow-sm)}
[data-theme="light"] #burgerBtn.is-open{background:var(--acc);color:#fff;border-color:transparent;box-shadow:0 2px 8px rgba(37,99,235,.3)}
[data-theme="light"] .mchip{background:#fff;border-color:#dde3ef;color:#0f172a;box-shadow:var(--shadow-sm)}
[data-theme="light"] .copyid{color:#0f172a;font-weight:700}
[data-theme="light"] .copybtn{background:#f1f5f9;border-color:#dde3ef;color:#374151}
[data-theme="light"] .copybtn:hover{background:#e2e8f0}

/* ── Карточки ── */
[data-theme="light"] .card{
  background:#fff;border-color:#dde3ef;
  box-shadow:var(--shadow-sm);
}
[data-theme="light"] .card:hover{border-color:#c5cfe0;box-shadow:var(--shadow-md)}
[data-theme="light"] .card-title{color:#0f172a;font-weight:700}

/* ── Статус-бар чипы (si) ── */
[data-theme="light"] .si{
  background:#fff;border-color:#dde3ef;
  box-shadow:var(--shadow-sm);
}
[data-theme="light"] .si:hover{border-color:#c5cfe0;box-shadow:var(--shadow-md)}
[data-theme="light"] .si-left{background:#f7f9fc;border-right:1px solid #dde3ef}
[data-theme="light"] .sname{color:#374151;font-weight:600}
[data-theme="light"] .sval{color:#0f172a;font-weight:800}

/* ── Аккордеоны (расширенные настройки) ── */
[data-theme="light"] .adv-wrap{
  background:#fff;border-color:#dde3ef;
  box-shadow:var(--shadow-sm);
}
[data-theme="light"] .adv-wrap:hover{border-color:#c5cfe0}
[data-theme="light"] .adv-hdr{background:#fff}
[data-theme="light"] .adv-hdr:hover{background:#f7f9fc}
[data-theme="light"] .adv-title{color:#0f172a;font-weight:800}
[data-theme="light"] .adv-sub{color:#64748b}
[data-theme="light"] .adv-body{background:#f7f9fc;border-top:1px solid #dde3ef}
[data-theme="light"] .adv-inner{background:#f7f9fc}

/* ── Внутренние аккордеоны (acc) ── */
[data-theme="light"] .acc-hdr{border-color:#dde3ef;background:#fff}
[data-theme="light"] .acc-hdr:hover{background:#f1f5f9}
[data-theme="light"] .acc-title{color:#0f172a;font-weight:700}
[data-theme="light"] .acc-body{background:#fff;border:1px solid #dde3ef;border-top:none;border-radius:0 0 var(--rs) var(--rs)}
[data-theme="light"] .acc-inner{background:#fff}
[data-theme="light"] .acc-grid{background:#fff}

/* ── Поля ввода ── */
[data-theme="light"] input,[data-theme="light"] select,[data-theme="light"] textarea{
  background:#fff;border-color:#dde3ef;color:#0f172a;
  box-shadow:inset 0 1px 3px rgba(15,23,42,.05);
}
[data-theme="light"] input:focus,[data-theme="light"] select:focus,[data-theme="light"] textarea:focus{
  border-color:var(--acc);box-shadow:0 0 0 3px rgba(37,99,235,.12),inset 0 1px 2px rgba(15,23,42,.03);
}
[data-theme="light"] label{color:#374151 !important;font-weight:600}
[data-theme="light"] select option{background:#fff;color:#0f172a}

/* ── Кнопки ── */
[data-theme="light"] .btn{border-color:#dde3ef}
[data-theme="light"] .btn.secondary{background:#fff;border-color:#dde3ef;color:#0f172a;box-shadow:var(--shadow-sm)}
[data-theme="light"] .btn.secondary:hover{background:#f1f5f9;border-color:#c5cfe0}
[data-theme="light"] .btn.primary{box-shadow:0 2px 8px rgba(37,99,235,.25)}
[data-theme="light"] .btn.primary:hover{box-shadow:0 4px 16px rgba(37,99,235,.35)}

/* ── Текст и метки ── */
[data-theme="light"] .ir-label{color:#475569;font-weight:600}
[data-theme="light"] .ir-val{color:#0f172a;font-weight:700}
[data-theme="light"] .ir-row{border-bottom-color:#edf0f7}
[data-theme="light"] small,[data-theme="light"] .hint{color:#64748b}
[data-theme="light"] .badge-ok{color:#15803d;background:rgba(21,128,61,.1);border-color:rgba(21,128,61,.2)}
[data-theme="light"] .badge-bad{color:#dc2626;background:rgba(220,38,38,.08);border-color:rgba(220,38,38,.18)}
[data-theme="light"] .live-dot{box-shadow:0 0 0 3px rgba(21,128,61,.18)}

/* ── Сообщения ── */
[data-theme="light"] .msg,.okline{border-color:rgba(21,128,61,.2);background:rgba(21,128,61,.07);color:#15803d}
[data-theme="light"] .err,.badline{border-color:rgba(220,38,38,.18);background:rgba(220,38,38,.06);color:#dc2626}

/* ── Боковая панель (nav) ── */
[data-theme="light"] #navOverlay{background:rgba(15,23,42,.35)}
[data-theme="light"] .nav{
  background:#fff;border-right:1px solid #dde3ef;
  box-shadow:8px 0 32px rgba(15,23,42,.1);
}
[data-theme="light"] .nav-header{border-bottom-color:#dde3ef;background:#f7f9fc}
[data-theme="light"] .nav-close{background:#fff;border-color:#dde3ef;color:#475569}
[data-theme="light"] .nav-close:hover{background:#f1f5f9}
[data-theme="light"] .nav-sep{background:#dde3ef}
[data-theme="light"] .nav-section-label{color:#94a3b8;font-size:10px;letter-spacing:.8px}
[data-theme="light"] .nav a,[data-theme="light"] .nav button{color:#1e293b}
[data-theme="light"] .nav a:hover,[data-theme="light"] .nav button:hover{background:#f1f5f9}
[data-theme="light"] .nav a:active,[data-theme="light"] .nav button:active{background:#e8edf5}
[data-theme="light"] .nav a.primary,[data-theme="light"] .nav button.primary{color:#fff;box-shadow:0 2px 8px rgba(37,99,235,.2)}
[data-theme="light"] .nav a.primary:hover,[data-theme="light"] .nav button.primary:hover{
  background:linear-gradient(135deg,var(--acc),var(--acc2),var(--acc3));
  color:#fff;
  box-shadow:0 4px 14px rgba(37,99,235,.3);
}
[data-theme="light"] .nav-home-btn{color:var(--acc) !important;background:#eff6ff !important;border:1px solid #bfdbfe !important}
[data-theme="light"] .nav-home-btn:hover{background:#dbeafe !important}
[data-theme="light"] .nav-theme-btn{color:#64748b !important}

/* ── Заголовок Atlanta Router ── */
[data-theme="light"] #atlTitle{
  background:linear-gradient(135deg,#2563eb 0%,#1d4ed8 50%,#7c3aed 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
[data-theme="light"] .nav-header-title{
  background:linear-gradient(135deg,var(--acc),var(--acc2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}

/* ── Wizard в светлой теме ── */
[data-theme="light"] #wizOverlay{background:rgba(15,23,42,.5)}
[data-theme="light"] .wiz-box{background:#fff;border-color:#dde3ef;box-shadow:var(--shadow-lg)}
[data-theme="light"] .wiz-title{color:#0f172a}
[data-theme="light"] .wiz-desc{color:#475569}
[data-theme="light"] .wiz-progress{background:#edf0f7}
[data-theme="light"] .wiz-band-tabs{background:#f1f5f9;border-color:#dde3ef}
[data-theme="light"] .wiz-band{color:#64748b}
[data-theme="light"] .wiz-skip{color:#94a3b8}
[data-theme="light"] .wiz-skip:hover{color:#475569}
[data-theme="light"] #wizOverlay{background:rgba(15,23,42,.45)}
[data-theme="light"] .wiz-box{background:var(--s1);border-color:var(--b1);box-shadow:0 16px 48px rgba(0,0,0,.15)}
[data-theme="light"] .wiz-step{color:var(--txt)}
[data-theme="light"] .wiz-desc{color:var(--mut)}
[data-theme="light"] .wiz-progress{background:var(--s3)}
[data-theme="light"] .wiz-band-tabs{background:var(--s3);border-color:var(--b1)}
[data-theme="light"] .wiz-band{color:var(--dim)}
[data-theme="light"] .wiz-skip{color:var(--dim)}
/* ── Nav utility кнопки ─────────────────────────────── */
.nav-home-btn{
  background:var(--s2);border:1px solid var(--b2) !important;
  font-weight:700 !important;color:var(--acc) !important;
  border-radius:10px !important;
}
.nav-home-btn:hover{background:var(--s3) !important}
.nav-theme-btn{color:var(--dim) !important;font-size:12px !important;font-weight:600 !important}
/* ── Wizard (мастер первого запуска) ────────────────── */
#wizOverlay{
  display:none;position:fixed;inset:0;z-index:500;
  background:rgba(0,0,0,.82);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);
  align-items:center;justify-content:center;padding:16px;
}
#wizOverlay.on{display:flex}
.wiz-box{
  width:100%;max-width:460px;
  background:var(--s1);border:1px solid var(--b2);
  border-radius:24px;overflow:hidden;
  animation:fadeUp .3s ease both;
}
.wiz-progress{height:3px;background:var(--b1)}
.wiz-progress-bar{height:3px;background:linear-gradient(90deg,var(--acc),var(--acc2));transition:width .4s ease}
.wiz-step{display:none;padding:28px 24px 24px;flex-direction:column;gap:16px}
.wiz-step.active{display:flex}
.wiz-icon{font-size:36px;text-align:center}
.wiz-title{font-size:18px;font-weight:800;letter-spacing:-.3px;text-align:center}
.wiz-desc{font-size:13px;color:var(--mut);text-align:center;line-height:1.6}
.wiz-field{display:flex;flex-direction:column;gap:6px}
.wiz-field label{font-size:12px;font-weight:700;color:var(--dim);text-transform:uppercase;letter-spacing:.4px}
.wiz-actions{display:flex;gap:8px;margin-top:4px}
.wiz-actions .btn{flex:1}
.wiz-skip{background:none;border:none;color:var(--dim);font-size:12px;text-align:center;cursor:pointer;padding:4px;text-decoration:underline}
.wiz-skip:hover{color:var(--txt)}
#wizWanPPP,#wizWanStatic{flex-direction:column;gap:10px}
.wiz-band-tabs{display:flex;background:var(--s2);border:1px solid var(--b1);border-radius:10px;padding:3px;gap:3px}
.wiz-band{flex:1;padding:7px 0;border-radius:7px;border:none;background:transparent;color:var(--mut);font-size:13px;font-weight:600;cursor:pointer;transition:background .15s,color .15s}
.wiz-band.active{background:var(--acc);color:#fff;box-shadow:0 1px 6px rgba(37,99,235,.3)}

@keyframes _spin{to{transform:rotate(360deg)}}
#loadingOverlay{display:none;position:fixed;inset:0;z-index:9000;background:rgba(0,0,0,.75);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);align-items:center;justify-content:center;flex-direction:column;gap:18px}
#loadingOverlay.on{display:flex !important}
.ld-ring{width:56px;height:56px;border:4px solid rgba(255,255,255,.12);border-top-color:var(--acc);border-radius:50%;animation:_spin .75s linear infinite}
.ld-text{font-size:16px;font-weight:700;color:#fff;text-align:center;max-width:280px;line-height:1.5}
.ld-sub{font-size:12px;color:rgba(255,255,255,.5);text-align:center;max-width:280px;margin-top:-10px}
</style>
