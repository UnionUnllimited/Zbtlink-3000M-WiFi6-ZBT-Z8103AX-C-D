}
function wizGoTo(n){
  _wizStep = n;
  var steps = document.querySelectorAll('.wiz-step');
  for(var i=0;i<steps.length;i++) steps[i].classList.remove('active');
  var cur = document.getElementById('wiz'+n);
  if(cur) cur.classList.add('active');
  // Прогресс: шаг 0 = 0%, шаг 3 = 100%
  var pct = n === 0 ? 0 : Math.round((n / (steps.length - 1)) * 100);
  var bar = document.getElementById('wizBar');
  if(bar) bar.style.width = pct + '%';
}
function wizWanChange(){
  var proto = (document.getElementById('wizWanProto')||{}).value||'dhcp';
  var ppp    = document.getElementById('wizWanPPP');
  var st     = document.getElementById('wizWanStatic');
  var srvWrap= document.getElementById('wizL2tpServerWrap');
  if(ppp) ppp.style.display   = (proto==='pppoe'||proto==='l2tp'||proto==='pptp') ? 'flex' : 'none';
  if(st)  st.style.display    = (proto==='static') ? 'flex' : 'none';
  if(srvWrap) srvWrap.style.display = (proto==='l2tp'||proto==='pptp') ? '' : 'none';
}
function wizNext(skip){
  // Шаг 0 → 1
  if(_wizStep === 0){ wizGoTo(1); return; }
  // Шаг 1: WiFi
  if(_wizStep === 1){
    if(!skip){
      var ssid  = ((document.getElementById('wizSsid') ||{}).value||'').trim();
      var key   = ((document.getElementById('wizKey')  ||{}).value||'').trim();
      var ssid5 = ((document.getElementById('wizSsid5')||{}).value||'').trim();
      var key5  = ((document.getElementById('wizKey5') ||{}).value||'').trim();
      var err   = document.getElementById('wizWifiErr');
      if(ssid && ssid.length < 2){ if(err){err.textContent='Имя 2.4 ГГц слишком короткое.';err.style.display='';} return; }
      if(key  && key.length  < 8){ if(err){err.textContent='Пароль 2.4 ГГц: минимум 8 символов.';err.style.display='';} return; }
      if(ssid5 && ssid5.length < 2){ if(err){err.textContent='Имя 5 ГГц слишком короткое.';err.style.display='';} return; }
      if(key5  && key5.length  < 8){ if(err){err.textContent='Пароль 5 ГГц: минимум 8 символов.';err.style.display='';} return; }
      if(err) err.style.display='none';
      _wizSkipWifi = false;
    } else { _wizSkipWifi = true; }
    wizGoTo(2); return;
  }
  // Шаг 2: WAN
  if(_wizStep === 2){
    if(!skip){
      var proto  = (document.getElementById('wizWanProto')||{}).value||'dhcp';
      var err    = document.getElementById('wizWanErr');
      var ok = true;
      if(proto==='pppoe'||proto==='l2tp'||proto==='pptp'){
        var u=(document.getElementById('wizPppUser')||{}).value||'';
        var p=(document.getElementById('wizPppPass')||{}).value||'';
        if(!u.trim()){ if(err){err.textContent='Введите логин провайдера.';err.style.display='';} return; }
        if(!p){        if(err){err.textContent='Введите пароль провайдера.';err.style.display='';} return; }
      }
      if(proto==='static'){
        var ip=(document.getElementById('wizStaticIp')||{}).value||'';
        if(!ip.trim()){ if(err){err.textContent='Введите IP адрес.';err.style.display='';} return; }
      }
      if(err) err.style.display='none';
      _wizSkipWan = false;
    } else { _wizSkipWan = true; }
    wizGoTo(3); return;
  }
  // Шаг 3: пароль панели
  if(_wizStep === 3){ wizFinish(false); }
}
function wizPrev(){
  if(_wizStep > 0) wizGoTo(_wizStep - 1);
}
function wizFinish(skip){
  try{localStorage.setItem('atlWizDone','1');}catch(e){}
  var ov = document.getElementById('wizOverlay');
  if(skip){ if(ov) ov.classList.remove('on'); return; }
  // Проверка учётных данных
  var user = ((document.getElementById('wizUser')||{}).value||'').trim();
  var pass = ((document.getElementById('wizPass')||{}).value||'').trim();
  var err  = document.getElementById('wizCredsErr');
  if(user && user.length < 5){ if(err){err.textContent='Логин: минимум 5 символов.';err.style.display='';} return; }
  if(pass && pass.length < 8){ if(err){err.textContent='Пароль: минимум 8 символов.';err.style.display='';} return; }
  if(err) err.style.display='none';
  if(ov) ov.classList.remove('on');
  // Собираем все поля
  var fields = {action:'setup_wizard'};
  // WiFi
  if(!_wizSkipWifi){
    var _s24 = ((document.getElementById('wizSsid') ||{}).value||'').trim();
    var _k24 = ((document.getElementById('wizKey')  ||{}).value||'').trim();
    var _s5  = ((document.getElementById('wizSsid5')||{}).value||'').trim();
    var _k5  = ((document.getElementById('wizKey5') ||{}).value||'').trim();
    // Если 5 ГГц пуста — копируем из 2.4
    if(!_s5 && _s24) _s5 = _s24 + '-5G';
    if(!_k5 && _k24) _k5 = _k24;
    fields.ssid_24 = _s24;
    fields.key_24  = _k24;
    fields.ssid_5  = _s5;
    fields.key_5   = _k5;
  }
  // WAN
  if(!_wizSkipWan){
    var proto = (document.getElementById('wizWanProto')||{}).value||'dhcp';
    fields.wan_proto = proto;
    if(proto==='pppoe'||proto==='l2tp'||proto==='pptp'){
      fields.pppoe_user   = ((document.getElementById('wizPppUser')   ||{}).value||'').trim();
      fields.pppoe_pass   = ((document.getElementById('wizPppPass')   ||{}).value||'').trim();
      fields.l2tp_server  = ((document.getElementById('wizL2tpServer')||{}).value||'').trim();
    }
    if(proto==='static'){
      fields.static_ip   = ((document.getElementById('wizStaticIp')  ||{}).value||'').trim();
      fields.static_mask = ((document.getElementById('wizStaticMask')||{}).value||'255.255.255.0').trim();
      fields.static_gw   = ((document.getElementById('wizStaticGw')  ||{}).value||'').trim();
      fields.static_dns1 = ((document.getElementById('wizStaticDns') ||{}).value||'').trim();
    }
  }
  // Учётные данные
  if(user) fields.new_user = user;
  if(pass) fields.new_pass = pass;
  // Отправляем форму
  var f = document.createElement('form');
  f.method = 'POST'; f.action = '/cgi-bin/panel';
  Object.keys(fields).forEach(function(k){
    var inp=document.createElement('input');inp.type='hidden';inp.name=k;inp.value=fields[k];f.appendChild(inp);
  });
  document.body.appendChild(f); f.submit();
}

// ── Init ──────────────────────────────────────────────────────
window.addEventListener('load', function(){
  if(ATL_SETUP_DONE !== '1'){
    var _wd=false; try{_wd=localStorage.getItem('atlWizDone')==='1';}catch(e){}
    if(!_wd) wizShow();
  } else if(${DEFAULT_WARN} === 1){
    var m = g('modal'); if(m) m.style.display='flex';
  }
  updateWanFields();
  // Stagger card animations
  var cards = document.querySelectorAll('.card');
  for(var i=0;i<cards.length;i++){
    cards[i].style.opacity = '0';
    cards[i].style.animation = 'fadeUp .35s ' + (0.05 + i*0.035) + 's ease both';
    cards[i].style.animationFillMode = 'both';
  }
  initSsidFields();
  // Bypass wait: если только что нажали включить/выключить VPN — ждём запуска сервиса
  var _bw = ((location.search.match(/[?&]bw=(\d+)/) || [0,0])[1] | 0);
  if(_bw > 0){
    var bsd = g('sdot-bypass'); if(bsd) bsd.className='sdot loading';
    var bsv = g('sv-bypass'); if(bsv) bsv.textContent='Применяется...';
    var blc = g('bypass-label-card'); if(blc) blc.textContent='Применяется...';
    var bbtn = g('bypassBtn'); if(bbtn) bbtn.disabled=true;
    setTimeout(function(){ if(bbtn) bbtn.disabled=false; pollStatus(); }, _bw*1000);
  } else {
    pollStatus();
  }
  setInterval(pollStatus, 30000);
  fetchDevices();
  fetchStats();
  setInterval(fetchDevices, 20000);
  setInterval(fetchStats, 30000);
  pingNodes();
  // Авто-закрытие уведомлений через 4 сек
  document.querySelectorAll('.msg,.err').forEach(function(el){
    setTimeout(function(){
      el.style.transition='opacity .5s';
      el.style.opacity='0';
      setTimeout(function(){ el.style.display='none'; }, 500);
    }, 4000);
  });
});

// ── Роутинг: ?page=adv → страница расширенных настроек ──────
(function(){
