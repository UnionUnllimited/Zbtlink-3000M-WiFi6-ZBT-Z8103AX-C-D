var _pingCache = {};

function pingNodes(){
  var btn = g('pingBtn');
  var status = g('ping-status');
  var sel = g('pw_node');
  if(!sel) return;
  if(btn){ btn.disabled = true; btn.textContent = '⏳…'; }
  if(status) status.textContent = 'URL Test — проверка серверов…';

  fetch('/cgi-bin/panel?action=api_ping_nodes', {credentials:'include'})
    .then(function(r){ return r.json(); })
    .then(function(data){
      _pingCache = data;
      // Обновляем опции select
      var opts = sel.options;
      for(var i = 0; i < opts.length; i++){
        var val = opts[i].value;
        var ms  = data[val];
        // Убираем старый пинг из текста
        var txt = opts[i].text.replace(/\s+\d+ms$|\s+—$/, '').replace(/\s+⏳$/, '');
        if(ms !== undefined && ms >= 0){
          var color = ms < 80 ? '🟢' : ms < 200 ? '🟡' : '🔴';
          opts[i].text = txt + '  ' + color + ' ' + ms + 'ms';
        } else if(ms === -1){
          opts[i].text = txt + '  —';
        }
      }
      if(btn){ btn.disabled = false; btn.textContent = '🏓 URL Test'; }
      if(status) status.textContent = '✅ Выберите сервер с наименьшей задержкой';
      setTimeout(function(){ if(status) status.textContent = ''; }, 4000);
    })
    .catch(function(e){
      if(btn){ btn.disabled = false; btn.textContent = '🏓 URL Test'; }
      if(status) status.textContent = '❌ Ошибка URL Test';
    });
