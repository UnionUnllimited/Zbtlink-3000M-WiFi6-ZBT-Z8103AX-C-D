    BYPASS_DESC="VPN выключен — некоторые сайты могут быть недоступны."
    BYPASS_DOT="bad"
    ;;
esac

INSTALLED_VER="$(panel_version)"

GUEST_STATE="$(guest_state)"
case "$GUEST_STATE" in
