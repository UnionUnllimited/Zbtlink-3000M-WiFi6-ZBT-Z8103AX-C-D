            <span style="background:var(--s3);border:1px solid var(--b1);border-right:0;border-radius:8px 0 0 8px;padding:9px 10px;font-size:13px;font-weight:700;color:var(--acc);white-space:nowrap;min-height:40px;display:flex;align-items:center;flex-shrink:0">Atlanta-</span>
            <input class="inp" id="wizSsid5" type="text" placeholder="MyHome-5G" autocomplete="off" spellcheck="false" style="border-radius:0 8px 8px 0;flex:1;margin:0">
