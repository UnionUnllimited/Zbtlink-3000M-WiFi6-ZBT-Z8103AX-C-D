<script>
// ── helpers ──────────────────────────────────────────────────
function g(id){ return document.getElementById(id); }

// ── Validation ───────────────────────────────────────────────
function isAscii(s){
  for(var i=0;i<s.length;i++){ var c=s.charCodeAt(i); if(c<32||c>126) return false; }
  return true;
}
function isAsciiNoSpace(s){
  for(var i=0;i<s.length;i++){ var c=s.charCodeAt(i); if(c<33||c>126) return false; }
  return true;
}
function hasCyrillic(s){ return /[а-яёА-ЯЁ]/.test(s); }
function showFldErr(elOrId, msg){
  var el = typeof elOrId === 'string' ? g(elOrId) : elOrId;
  if(!el) return;
  el.style.borderColor = 'var(--bad)';
  el.style.boxShadow = '0 0 0 2px rgba(240,64,64,.2)';
  var existing = el.parentNode.querySelector('.fld-err[data-for="'+el.id+'"]');
  if(existing){ existing.textContent = '⚠ '+msg; return; }
  var err = document.createElement('div');
  err.className = 'fld-err';
  err.setAttribute('data-for', el.id);
  err.style.cssText = 'color:#ff8888;font-size:11px;margin-top:4px;font-weight:600;line-height:1.4';
  err.textContent = '⚠ '+msg;
  el.parentNode.insertBefore(err, el.nextSibling);
  el.focus();
}
function clearFldErrs(){
  var errs = document.querySelectorAll('.fld-err');
  for(var i=0;i<errs.length;i++) errs[i].remove();
  var inps = document.querySelectorAll('input');
  for(var i=0;i<inps.length;i++){ inps[i].style.borderColor=''; inps[i].style.boxShadow=''; }
}

function saveWifi(){
  clearFldErrs();
  var suf24El = g('ssid_24_suffix');
  var suf24 = suf24El ? suf24El.value.trim() : '';
  if(!suf24){ showFldErr('ssid_24_suffix','Название сети не может быть пустым'); return; }
  if(hasCyrillic(suf24)){ showFldErr('ssid_24_suffix','Кириллица не поддерживается в названии Wi-Fi. Используйте латинские буквы (A–Z), цифры и символы'); return; }
  if(!isAscii(suf24)){ showFldErr('ssid_24_suffix','Только латиница, цифры и символы (!, _, -, и т.д.). Кириллица и спецсимволы запрещены'); return; }
  if(suf24.length > 28){ showFldErr('ssid_24_suffix','Максимум 28 символов (+ "Atlanta-" = 32 итого)'); return; }
  var k24 = g('key_24') ? g('key_24').value : '';
  if(k24 && k24.length < 8){ showFldErr('key_24','Пароль: минимум 8 символов'); return; }
  if(k24 && hasCyrillic(k24)){ showFldErr('key_24','Пароль: кириллица не поддерживается, используйте латиницу'); return; }
  if(k24 && !isAsciiNoSpace(k24)){ showFldErr('key_24','Пароль: только латиница и символы, без пробелов'); return; }
  var suf5El = g('ssid_5_suffix');
  var suf5 = suf5El ? suf5El.value.trim() : '';
  if(suf5){
    if(hasCyrillic(suf5)){ showFldErr('ssid_5_suffix','Кириллица не поддерживается в названии Wi-Fi. Используйте латинские буквы'); return; }
    if(!isAscii(suf5)){ showFldErr('ssid_5_suffix','Только латиница, цифры и символы'); return; }
    if(suf5.length > 28){ showFldErr('ssid_5_suffix','Максимум 28 символов'); return; }
  }
  var k5 = g('key_5') ? g('key_5').value : '';
  if(k5 && k5.length < 8){ showFldErr('key_5','Пароль: минимум 8 символов'); return; }
  if(k5 && hasCyrillic(k5)){ showFldErr('key_5','Пароль: кириллица не поддерживается, используйте латиницу'); return; }
  if(k5 && !isAsciiNoSpace(k5)){ showFldErr('key_5','Пароль: только латиница и символы, без пробелов'); return; }
  pact('my_wifi',{ssid_24:g('ssid_24').value, key_24:k24, ssid_5:g('ssid_5').value, key_5:k5});
}

function saveAuth(){
  clearFldErrs();
  var nuEl = g('new_user'), npEl = g('new_pass');
  var nu = nuEl ? nuEl.value.trim() : '';
  var np = npEl ? npEl.value : '';
  if(!nu && !np){ showFldErr('new_user','Введите новый логин или пароль'); return; }
  if(nu){
    if(nu.length < 5){ showFldErr('new_user','Логин: минимум 5 символов'); return; }
    if(hasCyrillic(nu)){ showFldErr('new_user','Логин: кириллица запрещена, используйте латиницу и цифры'); return; }
    if(!isAsciiNoSpace(nu)){ showFldErr('new_user','Логин: только латинские буквы и цифры, без пробелов'); return; }
    if(nu.length > 32){ showFldErr('new_user','Логин: максимум 32 символа'); return; }
  }
  if(np){
    if(np.length < 8){ showFldErr('new_pass','Пароль: минимум 8 символов'); return; }
    if(hasCyrillic(np)){ showFldErr('new_pass','Пароль: кириллица запрещена, используйте латиницу'); return; }
    if(!isAsciiNoSpace(np)){ showFldErr('new_pass','Пароль: только латиница и символы, без пробелов'); return; }
  }
  pact('change_auth',{new_user:nu, new_pass:np});
}

// ── Refresh button ────────────────────────────────────────────
var _lastPollMs = 0;
var _pollTimeTimer = null;
function _updateRefreshTime(){
  var rt = g('refresh-time');
  if(!rt || !_lastPollMs) return;
  var sec = Math.round((Date.now() - _lastPollMs) / 1000);
  if(sec < 5) rt.textContent = 'Сейчас';
  else if(sec < 60) rt.textContent = sec + ' сек назад';
  else rt.textContent = Math.round(sec/60) + ' мин назад';
}
function pollStatusManual(){
  var icon = g('refresh-icon');
  if(icon) icon.style.transform = 'rotate(360deg)';
  setTimeout(function(){ if(icon) icon.style.transform = ''; }, 400);
  pollStatus();
}

var LOADING_MSGS = {
