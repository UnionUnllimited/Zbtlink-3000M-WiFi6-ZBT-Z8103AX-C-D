http_url_ok(){
  _url="$1"
  if command -v curl >/dev/null 2>&1; then
    _code="$(curl -k -L -s -o /dev/null -w '%{http_code}' --connect-timeout 4 --max-time 8 "$_url" 2>/dev/null || echo 000)"
    case "$_code" in
      ""|000) return 1 ;;
      *) return 0 ;;
    esac
  fi
  if command -v wget >/dev/null 2>&1; then
    wget -qO- --timeout=8 "$_url" >/dev/null 2>&1 && return 0
  fi
  return 1
}

tcp_host_ok(){
  _host="$1"; _port="${2:-443}"
  if command -v nc >/dev/null 2>&1; then
    nc -w 4 "$_host" "$_port" </dev/null >/dev/null 2>&1 && return 0
  fi
  ping -c1 -W2 -q "$_host" >/dev/null 2>&1
}

