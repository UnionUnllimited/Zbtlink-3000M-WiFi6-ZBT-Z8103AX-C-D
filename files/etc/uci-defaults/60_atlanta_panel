  try{localStorage.setItem('atlTheme',t);}catch(e){}
  var bl=document.getElementById('wizThemeLight'),bd=document.getElementById('wizThemeDark');
  if(bl) bl.style.borderColor=t==='light'?'var(--acc)':'var(--b2)';
