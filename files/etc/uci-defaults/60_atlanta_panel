function applyStatus(d){
  // WAN IP — обновляем только если пришло из API (актуальнее чем серверный рендер)
  var wip = d.wan_ip || '';
  var bOn = (d.bypass === 'on');
  setSval('sv-wan-ip', wip || 'Нет IP');
  setSdot('sdot-wan', wip.length > 0);

  setSval('dbg-ip', wip || 'Нет IP');
  setSval('dbg-gw', d.wan_gw || '—');
  setSval('adv-dbg-ip', wip || 'Нет IP');
  setSval('adv-dbg-gw', d.wan_gw || '—');
  setSval('adv-dbg-dns', d.wan_dns || '—');
  setSval('adv-dbg-if', d.wan_if || '—');
  setSval('adv-dbg-l3', d.wan_l3 || '—');
  // Реальный L3-интерфейс роутера из ifstatus/ubus. Без emoji-флагов: на части прошивок они рисуются квадратами.
  var _siC = g('si-country');
  var _sflag = g('sv-country-flag');
  var _sdotC = g('sdot-country');
  if(_siC && _sflag){
    var _if = (d.wan_l3 || d.wan_if || '').replace(/[^\w.\-:@]/g,'').slice(0,18);
    if(_if && _if.toLowerCase() !== 'n/a'){
      _sflag.textContent = _if;
      if(_sdotC) _sdotC.className = 'sdot ok';
      _siC.style.display = '';
    } else {
      _sflag.textContent = '';
      if(_sdotC) _sdotC.className = 'sdot bad';
      _siC.style.display = 'none';
    }
  }

  // Сервисы — точка + текст
  setSdot('sdot-inet', d.inet);   setSval('sv-inet', d.inet ? 'Работает' : 'Нет связи');
  setSdot('sdot-yt',   d.YT); setSval('sv-yt',   d.YT ? 'Доступен' : 'Недоступен');
  setSdot('sdot-tg',   d.TG); setSval('sv-tg',   d.TG ? 'Доступен' : 'Недоступен');
  setSdot('sdot-vk',   d.vk); setSval('sv-vk',   d.vk ? 'Доступен' : 'Недоступен');
  setSdot('sdot-ai',   d.ai); setSval('sv-ai',   d.ai ? 'Доступен' : 'Недоступен');
  setSdot('sdot-bypass', bOn);
  setSval('sv-bypass', bOn ? 'Включён' : 'Отключён');
  var blc = g('bypass-label-card');
  if(blc){
    blc.textContent = bOn ? 'Включён' : 'Отключён';
    blc.className = 'badge ' + (bOn ? 'badge-ok' : 'badge-bad');
  }
  var bdesc = g('bypass-desc');
  if(bdesc){
    var msg = bOn ? '' : 'VPN выключен — некоторые сайты могут быть недоступны.';
    bdesc.textContent = msg;
    bdesc.style.display = msg ? 'flex' : 'none';
  }
  var newAct = bOn ? 'bypass_disable' : 'bypass_enable';
  var newTxt = bOn ? 'Отключить VPN' : 'Включить VPN';
  var bbtn = g('bypassBtn');
  if(bbtn){ bbtn.textContent = newTxt; bbtn.setAttribute('onclick', "pact('"+newAct+"')"); }
  // Обновляем nav-кнопку и si-bypass onclick в соответствии с текущим состоянием
  var nbtn = g('navBypassBtn');
  if(nbtn){ nbtn.textContent = newTxt; nbtn.setAttribute('onclick', "pact('"+newAct+"')"); nbtn.setAttribute('data-act', newAct); }
  var sibd = g('siBypassDiv');
  if(sibd){ sibd.setAttribute('onclick', "pact('"+newAct+"')"); sibd.setAttribute('data-act', newAct); }

  // WAN warning — показываем ТОЛЬКО после получения ответа API
  var warn = g('wan-warn');
  if(warn){
    if(!wip){
      warn.innerHTML = '⚠️ Нет WAN IP — проверьте кабель или тип подключения. Для PPPoE IP может быть на интерфейсе <b>ppp0</b>.';
      warn.style.display = 'block';
    } else if(!d.inet){
      warn.innerHTML = '⚠️ IP получен (<b>' + wip + '</b>), но интернет недоступен. Проверьте шлюз, DNS или данные PPPoE/L2TP.';
      warn.style.display = 'block';
    } else {
      warn.style.display = 'none';
    }
  }
}

